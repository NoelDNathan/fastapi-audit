FROM python:3.11-slim

WORKDIR /app
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libmagic1 \
        shared-mime-info \
        build-essential \
        libcairo2-dev \
        pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Install dependencies
COPY requirement.txt requirement.dev.txt ./
RUN pip install --no-cache-dir -r requirement.txt -r requirement.dev.txt

# Copy application code
COPY . .

# Expose port
EXPOSE 8000

# Run with uvicorn in reload mode for development
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

